  "quotes": [
    { "text": "采菊东篱下，悠然见南山。", "by": "陶渊明" },
    { "text": "行到水穷处，坐看云起时。", "by": "王维" },
    { "text": "人生到处知何似，应似飞鸿踏雪泥。", "by": "苏轼" },
    { "text": "莫听穿林打叶声，何妨吟啸且徐行。", "by": "苏轼" },
    { "text": "仰天大笑出门去，我辈岂是蓬蒿人。", "by": "李白" },
    { "text": "星垂平野阔，月涌大江流。", "by": "杜甫" },
    { "text": "海上生明月，天涯共此时。", "by": "张九龄" },
    { "text": "落霞与孤鹜齐飞，秋水共长天一色。", "by": "王勃" },
    { "text": "春江潮水连海平，海上明月共潮生。", "by": "张若虚" },
    { "text": "纸上得来终觉浅，绝知此事要躬行。", "by": "陆游" },
    { "text": "问渠那得清如许？为有源头活水来。", "by": "朱熹" },
    { "text": "不畏浮云遮望眼，自缘身在最高层。", "by": "王安石" }
